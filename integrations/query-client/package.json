{
  "name": "@yas/query-client",
  "version": "0.0.0",
  "sideEffects": false,
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**"
  ],
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    },
    "./devtools": {
      "require": "./dist/devtools.js",
      "import": "./dist/devtools.mjs",
      "types": "./dist/devtools.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "pnpm eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tanstack/react-query": "5.28.6",
    "@tanstack/react-query-devtools": "5.28.6"
  },
  "devDependencies": {
    "@yas/tsconfig": "workspace:*",
    "@yas/build": "workspace:*"
  }
}
