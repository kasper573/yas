{
  "name": "@yas/style",
  "version": "0.0.0",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**"
  ],
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    },
    "./themes/*": {
      "require": "./dist/themes/*.js",
      "import": "./dist/themes/*.mjs",
      "types": "./dist/themes/*.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "pnpm eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@vanilla-extract/css": "1.14.0",
    "@vanilla-extract/recipes": "0.5.1",
    "@vanilla-extract/dynamic": "2.1.0",
    "clsx": "^2.1.0",
    "shallow-equal": "3.1.0",
    "vanilla-extract-constrained": "workspace:*",
    "vanilla-extract-recipe-factory": "workspace:*",
    "react-styled-factory": "workspace:*",
    "@yas/design-system": "workspace:*",
    "flattened": "workspace:*"
  },
  "devDependencies": {
    "@yas/tsconfig": "workspace:*",
    "@yas/build": "workspace:*",
    "csstype": "^3",
    "tiny-glob": "0.2.9"
  }
}
